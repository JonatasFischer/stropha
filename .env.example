# --- Embedding providers ---
# Voyage AI — recommended for highest code-retrieval quality.
# When unset, the system falls back to a local ONNX model via fastembed.
VOYAGE_API_KEY=

# Anthropic — reserved for Phase 2 (summary generation, HyDE).
ANTHROPIC_API_KEY=

# --- Paths ---
# Root of the codebase to index. Defaults to current working directory.
STROPHA_TARGET_REPO=

# Where the SQLite index lives.
STROPHA_INDEX_PATH=${HOME}/.stropha/index.db

# --- Models ---
# Voyage embedding model (used only if VOYAGE_API_KEY is set).
STROPHA_VOYAGE_EMBED_MODEL=voyage-code-3
STROPHA_VOYAGE_EMBED_DIM=512

# Local embedder (fastembed/ONNX). Default is the top open-source MTEB English model.
# Other strong options (all fastembed-supported):
#   mixedbread-ai/mxbai-embed-large-v1     (default, 1024d, ~0.64 GB)
#   BAAI/bge-large-en-v1.5                 (1024d, ~1.2 GB, solid English)
#   nomic-ai/nomic-embed-text-v1.5         (768d, ~0.52 GB, 8192-token context)
#   BAAI/bge-small-en-v1.5                 (384d, ~0.07 GB, fastest, weakest)
# WARNING: avoid jinaai/jina-embeddings-v2-base-code — ONNX-runtime instability
# on macOS aarch64 (hangs/crashes on the second consecutive embed call).
# Changing the model invalidates the index — rerun `stropha index --rebuild`.
STROPHA_LOCAL_EMBED_MODEL=mixedbread-ai/mxbai-embed-large-v1

# --- Behavior ---
STROPHA_LOG_LEVEL=INFO
STROPHA_MAX_FILE_BYTES=524288
