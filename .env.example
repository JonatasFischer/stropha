# --- Embedding providers ---
# Voyage AI (recommended by spec). Get a key at https://www.voyageai.com.
# When unset, the system falls back to a local ONNX model via fastembed.
VOYAGE_API_KEY=

# Anthropic (for Phase 2+: summary generation, HyDE).
ANTHROPIC_API_KEY=

# --- Paths ---
# Root of the codebase to index. Defaults to current working directory.
RAG_TARGET_REPO=/Users/jonatas/sources/mimoria

# Where the SQLite index lives.
RAG_INDEX_PATH=${HOME}/.mimoria-rag/index.db

# --- Models ---
# Voyage embedding model (used only if VOYAGE_API_KEY is set).
RAG_VOYAGE_EMBED_MODEL=voyage-code-3
RAG_VOYAGE_EMBED_DIM=512

# Local embedder (fastembed/ONNX). Default is code-specialized.
# Other strong options:
#   jinaai/jina-embeddings-v2-base-code   (default, 768d, ~0.64 GB, 30 PLs)
#   mixedbread-ai/mxbai-embed-large-v1    (1024d, ~0.64 GB, top open MTEB English)
#   BAAI/bge-large-en-v1.5                (1024d, ~1.2 GB, solid English baseline)
#   BAAI/bge-small-en-v1.5                (384d, ~0.07 GB, fastest, weakest quality)
#   nomic-ai/nomic-embed-text-v1.5        (768d, ~0.52 GB, 8192-token context)
# Changing the model invalidates the index — rerun `mimoria-rag index --rebuild`.
RAG_LOCAL_EMBED_MODEL=jinaai/jina-embeddings-v2-base-code

# --- Behavior ---
RAG_LOG_LEVEL=INFO
RAG_MAX_FILE_BYTES=524288
